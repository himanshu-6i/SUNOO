rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    function isValidTrack(data) {
      return data.keys().hasAll(['title', 'artist', 'ownerId', 'visibility', 'coverUrl', 'duration', 'audioUrl', 'genre', 'plays', 'createdAt'])
        && data.keys().size() == 10
        && data.title is string && data.title.size() > 0 && data.title.size() <= 100
        && data.artist is string && data.artist.size() > 0 && data.artist.size() <= 100
        && data.ownerId == request.auth.uid
        && data.visibility == 'public'
        && data.coverUrl is string && data.coverUrl.size() <= 1000
        && data.duration is string && data.duration.size() <= 10
        && data.audioUrl is string && data.audioUrl.size() <= 1000
        && data.genre is string && data.genre.size() <= 50
        && data.plays is number && data.plays == 0
        && data.createdAt == request.time;
    }

    match /tracks/{trackId} {
      // Any authenticated user can read public tracks
      allow read: if isSignedIn() && existing().visibility == 'public';

      // Create action
      allow create: if isSignedIn() 
        && isValidId(trackId)
        && isValidTrack(incoming());

      // Update action: only owner can update some fields
      allow update: if isSignedIn() 
        && isValidId(trackId)
        && existing().ownerId == request.auth.uid
        && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'coverUrl', 'visibility'])
        && (incoming().get('title', existing().title) is string && incoming().get('title', existing().title).size() <= 100)
        && incoming().ownerId == existing().ownerId // immutability
        && incoming().createdAt == existing().createdAt; // immutability

      // Delete action: only owner or admin can delete
      allow delete: if isSignedIn() 
        && isValidId(trackId)
        && (existing().ownerId == request.auth.uid || request.auth.token.email == 'hm5080408@gmail.com');
    }
  }
}
